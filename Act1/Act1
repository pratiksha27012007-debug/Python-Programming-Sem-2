num1=int(input("Enter Number1:"))
num2=int(input("Enter Number2:"))

sum=num1+num2
print("Addition=",sum)

sub=num1-num2
print("Subraction=",sub)

mult=num1*num2
print("Multiplication=",mult)

div=num1/num2
print("Division=",div)

mod=num1%num2
print("Modulus=",mod)
