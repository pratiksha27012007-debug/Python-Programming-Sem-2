# Movie Ticket Eligibility Checker

# 1. Take input from the user and convert it to an integer
age = int(input("Please enter your age: "))

# 2. Check the condition
if age >= 18:
    print("Eligibility: Access Granted. Enjoy the movie!")
else:
    print("Eligibility: Access Denied. You must be at least 18 years old.")
